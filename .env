# Flask
FLASK_ENV=development
SECRET_KEY=change-me-in-production-use-long-random-string
JWT_SECRET_KEY=change-me-jwt-secret
JWT_ACCESS_HOURS=1
JWT_REFRESH_DAYS=30

# Database
DATABASE_URL=postgresql://eventnet:eventnet@localhost:5432/eventnet

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
FRONTEND_URL=http://localhost:5173

# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# Google Gemini AI
GEMINI_API_KEY=your_gemini_api_key
OPENAI_API_KEY=your_openai_api_key
AI_PROVIDER=gemini

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
OAUTH_REDIRECT_URI=http://localhost:5173/auth/callback

# Email
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
SENDGRID_API_KEY=your_sendgrid_api_key
MAIL_DEFAULT_SENDER=noreply@eventnet.io

# QR Check-in
QR_TOKEN_SECRET=qr-secret-change-me
QR_TOKEN_EXPIRY_HOURS=24

# Uploads
UPLOAD_FOLDER=uploads

# Rate Limiting
RATELIMIT_DEFAULT=200 per hour
