# ─────────────────────────────────────────────────────────────────
#  EventNet – Environment Configuration
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────────────

# Flask environment: development | production | testing
FLASK_ENV=development

# MUST change in production – generate with:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-generate-with-secrets-token-hex-32
JWT_SECRET_KEY=change-me-jwt-secret-token-hex-32

# Database – SQLite (default, no setup needed)
# For Docker: DATABASE_URL=sqlite:////app/instance/eventnet.db
# DATABASE_URL=sqlite:///instance/eventnet.db
# DATABASE_URL=sqlite:///C:/Projects/eventnet/instance/eventnet.db
DATABASE_URL=sqlite:///instance/eventnet.db
# Server
HOST=0.0.0.0
PORT=5000

# ─── Razorpay Payment Gateway ────────────────────────────────────
# Get from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here

# ─── Admin Account (auto-created on first startup) ───────────────
ADMIN_EMAIL=admin@eventnet.io
ADMIN_PASSWORD=Admin@1234
